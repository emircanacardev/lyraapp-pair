<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Albüm kapağı + Şarkı bilgisi -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/notif_album_art"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_notif_album_art" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="4dp">

            <TextView
                android:id="@+id/notif_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Neon Sokaklar"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/notif_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Şehir Işıkları · Gece Vardiyası"
                android:textColor="#B3FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Kontrol butonları -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/notif_btn_favorite"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:padding="6dp"
            android:src="@drawable/ic_notif_fav_border" />

        <ImageButton
            android:id="@+id/notif_btn_previous"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="20dp"
            android:background="@android:color/transparent"
            android:padding="6dp"
            android:src="@drawable/ic_notif_previous" />

        <ImageButton
            android:id="@+id/notif_btn_pause"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="20dp"
            android:background="@drawable/bg_notif_pause_btn"
            android:padding="10dp"
            android:src="@drawable/ic_notif_pause" />

        <ImageButton
            android:id="@+id/notif_btn_next"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="20dp"
            android:background="@android:color/transparent"
            android:padding="6dp"
            android:src="@drawable/ic_notif_next" />
    </LinearLayout>

    <!-- İlerleme çubuğu -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/notif_current_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1:33"
            android:textColor="#B3FFFFFF"
            android:textSize="11sp" />

        <ProgressBar
            android:id="@+id/notif_progress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="3dp"
            android:layout_marginEnd="8dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:progress="41"
            android:progressDrawable="@drawable/bg_notif_progress" />

        <TextView
            android:id="@+id/notif_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3:43"
            android:textColor="#B3FFFFFF"
            android:textSize="11sp" />
    </LinearLayout>
</LinearLayout>
